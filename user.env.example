# Local overrides — copy this file to `user.env` and fill in your own values.
# `user.env` is gitignored, so your personal details never get committed.
# Sourced by scripts/post-install.sh.

# Git identity (used to set a global git user.name / user.email if none is set yet)
GIT_NAME="Your Name"
GIT_EMAIL="you@example.com"
